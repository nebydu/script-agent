{
  "permissions": {
    "deny": [
      "Edit(./docs/**)",
      "Write(./docs/**)",
      "NotebookEdit(./docs/**)",
      "Edit(../monitoring-meta/**)",
      "Write(../monitoring-meta/**)",
      "NotebookEdit(../monitoring-meta/**)",
      "Edit(../hub/**)",
      "Write(../hub/**)",
      "NotebookEdit(../hub/**)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "../monitoring-meta/docs",
      "../monitoring-meta/handoff"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-bash.cmd",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/deny-write-paths.sh"
            ]
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "monitoring-harness@monitoring-harness": true
  }
}
